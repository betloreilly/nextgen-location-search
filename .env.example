# Copy this file to .env and fill in your values (use any text editor).
# OpenSearch (required) — get URL, user, and password from your watsonx.data OpenSearch or other OpenSearch provider.
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=

# Backend server
PORT=3001
# Max search results returned (all modes). Default 10, range 1–100.
# SEARCH_RESULTS_SIZE=10

# LLM (Advanced mode) and embeddings — OpenAI-compatible API; use either key
LLM_API_KEY=
# OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Embeddings (place + review vectors); uses LLM_API_KEY or OPENAI_API_KEY
# EMBEDDING_MODEL=text-embedding-3-small

# Frontend (optional: override API URL when backend is elsewhere)
# NEXT_PUBLIC_API_URL=http://localhost:3001
